generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // directUrl = env("DIRECT_URL") // Buka komen ini jika Neon/Supabase Anda butuh direct URL
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  
  // Dibuat opsional (?) agar nanti bisa Login pakai Google/GitHub tanpa error
  password          String?   
  
  // Sistem Keamanan Ekstra
  pin               String?   // Security PIN 6-Digit
  resetOtp          String?   // Menyimpan kode OTP 6-Digit
  otpExpiry         DateTime? // Batas waktu OTP (misal: 10 menit)
  
  btcWallet         String?   @unique
  freeKeyActionUsed Boolean   @default(false)
  createdAt         DateTime  @default(now())

  orders            Order[]
  apiKeys           ApiKey[]
}

model Order {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  planType      String   // "1_MONTH", "3_MONTHS", "1_YEAR", "RENEWAL", "EXTRA_KEY"
  
  usdAmount     Float    
  btcAmount     Float    
  btcAddress    String   
  
  status        String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  
  // TAMBAHAN: Menyimpan Bukti Transfer Blockchain (Transaction Hash) setelah sukses
  txHash        String?  @unique
  
  targetKeyId   String?  
  createdAt     DateTime @default(now())
}

model ApiKey {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  name          String   @default("Main API Key")
  encryptedKey  String   
  iv            String   
  authTag       String   
  isActive      Boolean  @default(true)
  
  expiresAt     DateTime 
  createdAt     DateTime @default(now())
}